<style>
  .btn-search{
    background-color: #fe424d;
    color: #fff;
    border-radius: 10px;
  }
  .btn-search i{
    display: inline;
    margin-right: 0.5rem;
  }
  .src-input{
    border-radius: 15px;
  }
  
  /* Mobile navbar improvements */
  @media (max-width: 768px) {
    .navbar-nav {
      text-align: center;
    }
    
    .navbar-nav .nav-link {
      padding: 0.5rem 1rem;
      margin: 0.25rem 0;
    }
    
    .navbar-nav form.d-flex {
      margin: 1rem 0;
      padding: 0 1rem;
    }
    
    .src-input {
      margin-bottom: 0.5rem;
    }
    
    .btn-search {
      width: 100%;
      justify-content: center;
    }
    
    .navbar-toggler {
      border: none;
      padding: 0.25rem 0.5rem;
    }
    
    .navbar-toggler:focus {
      box-shadow: none;
    }
  }
  
  @media (max-width: 576px) {
    .btn-search i {
      margin-right: 0.25rem;
    }
    
    .navbar-brand {
      font-size: 1.25rem;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-ligth border-bottom sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
      <button class="navbar-toggler" 
      type="button" data-bs-toggle="collapse" 
      data-bs-target="#navbarNavAltMarkup" 
      aria-controls="navbarNavAltMarkup" 
      aria-expanded="false" 
      aria-label="Toggle navigation">

        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link" href="/listings">Explore</a>
        </div>
        <div class="navbar-nav ms-auto">
          <form class="d-flex">
          <input class="src-input form-control me-2" type="search" placeholder="Search" aria-label="Search">
          <button class="btn btn-search" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
        </div>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/listings/new">Travellis Home</a>
          <% if (currUser) { %>
            <span class="nav-link">Hello, <%= currUser.username %></span>
            <a class="nav-link" href="/logout"><b>Logout</b></a>
          <% } else { %>
            <a class="nav-link" href="/signup"><b>Sign up</b></a>
            <a class="nav-link" href="/login"><b>Login</b></a>
          <% } %>
          
        </div>
      </div>
    </div>
  </nav>
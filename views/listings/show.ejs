  <% layout("/layouts/boilerplate")%>
  <style>
    /* Mobile responsive styles for show page */
    @media (max-width: 768px) {
      .show-page-title {
        text-align: center;
        margin-bottom: 1rem;
      }
      
      .show-card {
        margin-left: 0 !important;
        margin-right: 0 !important;
      }
      
      .btns {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      
      .btns .btn {
        width: 100%;
      }
      
      .btns form {
        width: 100%;
      }
      
      .btns form .btn {
        width: 100%;
      }
      
      .review-form {
        margin-top: 2rem;
      }
      
      .review-cards {
        margin-top: 1rem;
      }
      
      .map-section {
        margin-top: 2rem;
        margin-left: 0 !important;
        margin-right: 0 !important;
      }
    }
  </style>
  <div class="row mt-3">
      <div class="col-12 col-md-8 offset-md-2 show-page-title">
        <h3><%= listing.title %></h3>
      </div>

      <div class="card col-12 col-md-6 offset-md-2 listing-card show-card">
        <img 
          src="<%=listing.image.url%>" 
          class="card-img-top show-img" 
          alt="listing-image"
        />

        <div class="card-body">
          <p class="card-text"><br>
            <i>Owned by <%=listing.owner.username%></i><br>
            <%= listing.description %><br><br>
            Price: &#8377; <%= listing.price.toLocaleString("en-IN") %> <br>
            Location: <%= listing.location %> <br>
            Country: <%= listing.country %>
          </p> <br>
        </div>
        
        <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
        <div class="btns">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark add-btn">Edit</a>
          <br /><br>
          <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
          <button class="btn btn-dark">Delete</button>
          </form>
        </div>
        <br>
        <% } %>
        <% if(currUser) { %>
        <div class="review-form">
          <h4>Leave a Review</h4>
          <form action="/listings/<%=listing._id %>/reviews" method="post" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-basic">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            </div>
            <div class="mb-3 mt-3">
              <label for="comment" class="form-label">Comment</label>
              <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
              <div class="invalid-feedback">please add some comments before submiting!</div>
            </div>
            <br>
            <button class="btn btn-outline-dark">Submit</button>
          </form>
          <% } %>
          <hr>
          <% if(listing.reviews.length > 0) { %>
          <div class="row review-cards">
            <p><b>All Reviews</b></p>
            <%for(review of listing.reviews) { %>
              <div class="card col-12 col-md-5 ms-md-3 mb-3">
                <div class="card-body">
                  <h5 class="card-tilte">@<%= review.author.username%></h5>
                  <p class="starability-result card-text" data-rating="<%=review.rating %>"></p>
                  <p class="card-text"> <%=review.comment %></p>
                  <form class="mb-3" method="post" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                    <button class="btn btn-sm btn-dark">Delete</button>
                  </form>
                </div>
              </div>  
            <% } %>
          </div>
          <% } %>
        </div>
      </div>
      <div class="col-12 col-md-6 offset-md-2 mb-3 map-section">
        <h3>Where you'll be...</h3>
        <div id="map"></div>
      </div>
  </div>
<script>
  // Pass listing coordinates to JavaScript
  window.listingData = {
    latitude: <%= listing.coordinates && listing.coordinates.latitude ? listing.coordinates.latitude : 'null' %>,
    longitude: <%= listing.coordinates && listing.coordinates.longitude ? listing.coordinates.longitude : 'null' %>,
    title: "<%= listing.title %>",
    location: "<%= listing.location %>"
  };
  
  // Debug: Log the listing data to console
  console.log('Listing Data:', window.listingData);
  console.log('Latitude:', window.listingData.latitude, 'Type:', typeof window.listingData.latitude);
  console.log('Longitude:', window.listingData.longitude, 'Type:', typeof window.listingData.longitude);
</script>
<script src="/js/map.js"></script>
